---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';

import vor1 from '../assets/images/vor1.jpeg';
import nach1 from '../assets/images/nach1.jpeg';
import vor2 from '../assets/images/vor2.jpeg';
import nach2 from '../assets/images/nach2.jpeg';
import vor3 from '../assets/images/vor3.jpeg';
import nach3 from '../assets/images/nach3.jpeg';
import vor4 from '../assets/images/vor4.jpeg';
import nach4 from '../assets/images/nach4.jpeg';
import vor5 from '../assets/images/vor5.jpeg';
import nach5 from '../assets/images/nach5.jpeg';
import vor6 from '../assets/images/vor6.jpeg';
import nach6 from '../assets/images/nach6.jpeg';

const projects = [
  { before: vor1, after: nach1 },
  { before: vor2, after: nach2 },
  { before: vor3, after: nach3 },
  { before: vor4, after: nach4 },
  { before: vor5, after: nach5 },
  { before: vor6, after: nach6 },
];
---

<BaseLayout
  title="Referenzen | THZ Innenrenovierung-Hausmeisterdienste Siegen"
  description="Sehen Sie sich unsere abgeschlossenen Projekte an. Interaktive Vorher-Nachher-Vergleiche von Renovierungen, Bodenverlegungen und mehr in Siegen und Umgebung."
>
  <!-- Hero -->
  <section class="page-hero" aria-labelledby="page-title">
    <div class="container">
      <h1 id="page-title" class="page-title">Unsere Referenzen</h1>
      <p class="page-subtitle">
        Qualität, die Sie sehen können. Ziehen Sie den Regler und überzeugen Sie sich selbst.
      </p>
    </div>
  </section>

  <!-- Before / After Sliders -->
  <section class="sliders-section section" aria-labelledby="sliders-title">
    <div class="container">
      <h2 id="sliders-title" class="sr-only">Vorher-Nachher-Vergleiche</h2>

      <div class="sliders-list">
        {projects.map((project, index) => (
          <article class="ba-slider" data-ba-slider style={`--delay: ${index * 100}ms`}>
            <div class="ba-frame">
              <!-- After image (full background) -->
              <div class="ba-side ba-after">
                <Image
                  src={project.after}
                  alt="Nachher"
                  width={1200}
                  height={800}
                  class="ba-photo"
                />
                <span class="ba-tag ba-tag-after">Nachher</span>
              </div>

              <!-- Before image (clipped overlay) -->
              <div class="ba-side ba-before" data-ba-before>
                <Image
                  src={project.before}
                  alt="Vorher"
                  width={1200}
                  height={800}
                  class="ba-photo"
                />
                <span class="ba-tag ba-tag-before">Vorher</span>
              </div>

              <!-- Divider with handle -->
              <div class="ba-divider" data-ba-divider role="slider" aria-valuemin="0" aria-valuemax="100" aria-valuenow="50" aria-label="Vorher-Nachher-Vergleich">
                <div class="ba-handle" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m11 17-5-5 5-5"/>
                    <path d="m13 7 5 5-5 5"/>
                  </svg>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-alt" aria-labelledby="cta-title">
    <div class="container">
      <div class="cta-box">
        <h2 id="cta-title" class="cta-title">Werden Sie unser nächstes Referenzprojekt?</h2>
        <p class="cta-text">Wir freuen uns darauf, auch Ihr Vorhaben professionell umzusetzen.</p>
        <a href="/kontakt" class="btn btn-primary btn-lg">
          Projekt besprechen
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/>
            <path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Page Hero */
  .page-hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: var(--color-white);
    padding: var(--spacing-3xl) 0;
    text-align: center;
  }

  .page-title {
    color: var(--color-white);
    font-size: 2.5rem;
    margin-bottom: var(--spacing-md);
  }

  .page-subtitle {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Sliders Section */
  .sliders-section {
    background-color: var(--color-white);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .sliders-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3xl);
    align-items: center;
  }

  /* Before/After Slider */
  .ba-slider {
    --pos: 50%;
    width: 100%;
    max-width: 1000px;
    opacity: 0;
    transform: translateY(30px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--delay, 0ms);
  }

  .ba-slider.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ba-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 20px 50px -12px rgba(0, 0, 0, 0.18);
    background-color: var(--color-gray-100);
    cursor: pointer;
  }

  .ba-side {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .ba-after {
    z-index: 1;
  }

  .ba-before {
    z-index: 2;
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
    will-change: clip-path;
  }

  .ba-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    user-select: none;
    pointer-events: none;
  }

  /* Tags */
  .ba-tag {
    position: absolute;
    top: 16px;
    z-index: 3;
    padding: 6px 12px;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-white);
    backdrop-filter: blur(4px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    pointer-events: none;
  }

  .ba-tag-before {
    left: 16px;
    background-color: rgba(0, 53, 64, 0.9);
  }

  .ba-tag-after {
    right: 16px;
    background-color: rgba(253, 89, 9, 0.9);
  }

  /* Divider & Handle */
  .ba-divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--pos);
    width: 3px;
    background: rgba(255, 255, 255, 0.95);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.08),
      0 0 20px rgba(0, 0, 0, 0.25);
    z-index: 4;
    transform: translateX(-50%);
    cursor: ew-resize;
    will-change: left;
  }

  .ba-divider::before {
    content: '';
    position: absolute;
    inset: -12px -24px;
    background: transparent;
  }

  .ba-handle {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    background: var(--color-white);
    border: 3px solid var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ba-slider:hover .ba-handle,
  .ba-divider:active .ba-handle {
    transform: translate(-50%, -50%) scale(1.08);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.35);
  }

  /* CTA Alternative */
  .cta-alt {
    background-color: var(--color-gray-50);
  }

  .cta-box {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-box .cta-title {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .cta-box .cta-text {
    margin-bottom: var(--spacing-lg);
  }

  /* Responsive */
  @media (min-width: 768px) {
    .ba-frame {
      aspect-ratio: 16 / 10;
    }

    .ba-handle {
      width: 60px;
      height: 60px;
    }

    .ba-tag {
      font-size: 0.75rem;
      top: 20px;
      padding: 8px 14px;
    }

    .ba-tag-before {
      left: 20px;
    }

    .ba-tag-after {
      right: 20px;
    }
  }
</style>

<script>
  (function () {
    const sliders = document.querySelectorAll('[data-ba-slider]');

    sliders.forEach((slider) => {
      const divider = slider.querySelector('[data-ba-divider]');
      let isDragging = false;

      const setPos = (clientX) => {
        const rect = slider.getBoundingClientRect();
        let pos = ((clientX - rect.left) / rect.width) * 100;
        pos = Math.max(2, Math.min(98, pos));
        slider.style.setProperty('--pos', pos + '%');
        divider.setAttribute('aria-valuenow', Math.round(pos));
      };

      const onMove = (e) => {
        if (!isDragging) return;
        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
        setPos(clientX);
      };

      const onEnd = () => {
        isDragging = false;
      };

      divider.addEventListener('mousedown', (e) => {
        isDragging = true;
        e.preventDefault();
      });

      divider.addEventListener('touchstart', (e) => {
        isDragging = true;
      }, { passive: true });

      window.addEventListener('mousemove', onMove);
      window.addEventListener('touchmove', onMove, { passive: true });
      window.addEventListener('mouseup', onEnd);
      window.addEventListener('touchend', onEnd);

      slider.addEventListener('click', (e) => {
        if (e.target.closest('[data-ba-divider]')) return;
        const clientX = e.clientX;
        setPos(clientX);
      });
    });

    const reveal = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          reveal.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

    sliders.forEach((s) => reveal.observe(s));
  })();
</script>
