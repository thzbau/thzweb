---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('legal', 'impressum');
if (!entry) {
  throw new Error('Impressum nicht gefunden');
}
const { Content } = await render(entry);
const { title, description } = entry.data;
---

<BaseLayout
  title={title}
  description={description}
>
  <section class="page-content section" aria-labelledby="page-title">
    <div class="container">
      <div class="content-wrapper">
        <h1 id="page-title">Impressum</h1>
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-content {
    background-color: var(--color-white);
    padding-top: var(--spacing-2xl);
  }

  .content-wrapper {
    max-width: 768px;
    margin: 0 auto;
  }

  .content-wrapper :global(h1) {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--color-primary);
  }

  .content-wrapper :global(h2) {
    font-size: 1.5rem;
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
    color: var(--color-primary);
  }

  .content-wrapper :global(h3) {
    font-size: 1.25rem;
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .content-wrapper :global(p) {
    margin-bottom: var(--spacing-md);
    line-height: 1.7;
  }

  .content-wrapper :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    transition: color var(--transition-fast);
  }

  .content-wrapper :global(a:hover) {
    color: var(--color-accent);
  }

  .content-wrapper :global(strong) {
    color: var(--color-text-primary);
  }
</style>
