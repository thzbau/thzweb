---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Seite nicht gefunden | THZ Innenrenovierung"
  description="Die angeforderte Seite konnte nicht gefunden werden."
  noindex={true}
>
  <section class="error-page" aria-labelledby="error-title">
    <div class="container">
      <div class="error-content">
        <span class="error-code">404</span>
        <h1 id="error-title" class="error-title">Seite nicht gefunden</h1>
        <p class="error-text">
          Die von Ihnen gesuchte Seite existiert leider nicht oder wurde verschoben.
        </p>
        <div class="error-actions">
          <a href="/" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9 22 9 12 15 12 15 22"/>
            </svg>
            Zur Startseite
          </a>
          <a href="/" onclick="event.preventDefault(); history.back();" class="btn btn-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="m12 19-7-7 7-7"/>
              <path d="M19 12H5"/>
            </svg>
            Zurück
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .error-page {
    min-height: calc(100vh - 72px - 400px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-3xl) 0;
    background-color: var(--color-gray-50);
  }

  .error-content {
    text-align: center;
    max-width: 480px;
  }

  .error-code {
    display: block;
    font-size: 6rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1;
    margin-bottom: var(--spacing-md);
  }

  .error-title {
    font-size: 1.75rem;
    margin-bottom: var(--spacing-md);
  }

  .error-text {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-xl);
  }

  .error-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-md);
  }
</style>
