---
import BaseLayout from '../layouts/BaseLayout.astro';
import leistungenData from '../data/pages/leistungen.json';
import servicesData from '../data/services.json';

const { meta, hero, cta } = leistungenData;
---

<BaseLayout
  title={meta.title}
  description={meta.description}
>
  <!-- Hero -->
  <section class="page-hero" aria-labelledby="page-title">
    <div class="container">
      <h1 id="page-title" class="page-title">{hero.title}</h1>
      <p class="page-subtitle">
        {hero.subtitle}
      </p>
    </div>
  </section>

  <!-- Services Detail -->
  <section class="services-detail section" aria-label="Leistungsdetails">
    <div class="container">
      {servicesData.services.map((service, index) => (
        <article class={`service-block ${index % 2 === 0 ? 'left' : 'right'}`} id={service.id}>
          <div class="service-image-wrapper">
            <img 
              src={service.image} 
              alt={service.imageAlt}
              class="service-image"
              width={600}
              height={400}
              loading="lazy"
              decoding="async"
            />
          </div>
          
          <div class="service-content">
            <span class="service-subtitle">{service.subtitle}</span>
            <h2 class="service-title">{service.title}</h2>
            <p class="service-description">{service.detailDescription}</p>
            
            <ul class="feature-list">
              {service.features.map((feature) => (
                <li class="feature-item">
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feature-icon" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5"/>
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            
            <a href="/kontakt" class="btn btn-primary">
              Angebot anfordern
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14"/>
                <path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta-alt" aria-labelledby="cta-title">
    <div class="container">
      <div class="cta-box">
        <h2 id="cta-title" class="cta-title">{cta.title}</h2>
        <p class="cta-text">{cta.text}</p>
        <a href={cta.buttonHref} class="btn btn-primary btn-lg">{cta.buttonLabel}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Services Detail */
  .services-detail {
    background-color: var(--color-white);
  }

  .service-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-3xl);
    padding-bottom: var(--spacing-3xl);
    border-bottom: 1px solid var(--color-border);
  }

  .service-block:last-child {
    margin-bottom: 0;
    padding-bottom: 0;
    border-bottom: none;
  }

  .service-image-wrapper {
    order: 1;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }

  .service-block.right .service-image-wrapper {
    order: 1;
  }

  .service-block.right .service-content {
    order: 2;
  }

  .service-image {
    width: 100%;
    height: auto;
    aspect-ratio: 16/10;
    object-fit: cover;
    display: block;
  }

  .service-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .service-subtitle {
    display: inline-block;
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-sm);
  }

  .service-title {
    font-size: 1.75rem;
    margin-bottom: var(--spacing-md);
  }

  .service-description {
    font-size: 1.125rem;
    margin-bottom: var(--spacing-lg);
  }

  .feature-list {
    list-style: none;
    margin: 0 0 var(--spacing-xl) 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
  }

  .feature-icon {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  /* CTA Alternative */
  .cta-alt {
    background-color: var(--color-gray-50);
  }

  .cta-box {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }

  .cta-box .cta-title {
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .cta-box .cta-text {
    margin-bottom: var(--spacing-lg);
  }

  /* Responsive */
  @media (min-width: 1024px) {
    .service-block {
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .service-block.left .service-image-wrapper {
      order: 1;
    }

    .service-block.left .service-content {
      order: 2;
    }

    .service-block.right .service-image-wrapper {
      order: 2;
    }

    .service-block.right .service-content {
      order: 1;
    }
  }
</style>
