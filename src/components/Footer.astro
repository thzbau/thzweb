---
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.jpg';

const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'Trockenbau', href: '/leistungen#trockenbau' },
  { label: 'Bodenverlegung', href: '/leistungen#boden' },
  { label: 'Malerarbeiten', href: '/leistungen#maler' },
  { label: 'Hausmeisterdienste', href: '/leistungen#hausmeister' },
  { label: 'Referenzen', href: '/referenzen' },
];

const legalLinks = [
  { label: 'Impressum', href: '/impressum' },
  { label: 'Datenschutz', href: '/datenschutz' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <!-- Column 1: About -->
      <div class="footer-col">
        <a href="/" class="footer-logo">
          <Image 
            src={logo} 
            alt="THZ Innenrenovierung Logo" 
            class="footer-logo-image"
            width={86}
            height={50}
          />
        </a>
        <p class="footer-description">
          Ihr zuverlässiger Partner für Trockenbau, Bodenverlegung, Maler- & Tapezierarbeiten 
          und Renovierungen in Siegen & Umgebung. Sauber, schnell und professionell.
        </p>
        <div class="footer-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
          <span>Einzelunternehmen</span>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div class="footer-col">
        <h3 class="footer-title">Leistungen</h3>
        <ul class="footer-links">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Contact -->
      <div class="footer-col">
        <h3 class="footer-title">Kontakt</h3>
        <address class="footer-address">
          <div class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span>
              THZ Innenrenovierung<br />
              Roster str 66<br />
              57074 Siegen
            </span>
          </div>
          <div class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:015511693355" class="contact-link">
              0155 1169 3355
            </a>
          </div>
          <div class="contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
            <a href="mailto:Info@thz-renovierung.de" class="contact-link">
              Info@thz-renovierung.de
            </a>
          </div>
        </address>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <div class="footer-legal">
        <p class="copyright">
          © {currentYear} THZ Innenrenovierung-Hausmeisterdienste. Alle Rechte vorbehalten.
        </p>
        <nav class="legal-nav" aria-label="Rechtliche Links">
          {legalLinks.map((link, index) => (
            <>
              <a href={link.href} class="legal-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/>
                  <path d="M14 2v4a2 2 0 0 0 2 2h4"/>
                  <path d="M10 9H8"/>
                  <path d="M16 13H8"/>
                  <path d="M16 17H8"/>
                </svg>
                {link.label}
              </a>
              {index < legalLinks.length - 1 && <span class="legal-separator">|</span>}
            </>
          ))}
        </nav>
      </div>
      <p class="footer-credit">
        Inhaber: <strong>Halil Zeka</strong>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding-top: var(--spacing-3xl);
    padding-bottom: var(--spacing-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-2xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .footer-logo-image {
    height: 50px;
    width: auto;
    max-width: 200px;
    object-fit: contain;
    background-color: var(--color-white);
    padding: 8px 16px;
    border-radius: var(--radius-md);
  }

  .footer-description {
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.7;
    max-width: 320px;
  }

  .footer-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    background-color: rgba(255, 255, 255, 0.1);
    padding: var(--spacing-xs) var(--spacing-sm);
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    width: fit-content;
  }

  .footer-title {
    color: var(--color-white);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-accent);
  }

  .footer-address {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    font-style: normal;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    color: rgba(255, 255, 255, 0.8);
  }

  .contact-link {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .contact-link:hover,
  .contact-link:focus-visible {
    color: var(--color-accent);
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    padding-top: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
    align-items: center;
    text-align: center;
  }

  .footer-legal {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    align-items: center;
  }

  .copyright {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    margin: 0;
  }

  .legal-nav {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    justify-content: center;
  }

  .legal-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color var(--transition-fast);
  }

  .legal-link:hover,
  .legal-link:focus-visible {
    color: var(--color-accent);
  }

  .legal-separator {
    color: rgba(255, 255, 255, 0.3);
  }

  .footer-credit {
    color: rgba(255, 255, 255, 0.75);
    font-size: 0.75rem;
    margin: 0;
  }

  /* Responsive */
  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr;
      gap: var(--spacing-3xl);
    }

    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }

    .footer-legal {
      flex-direction: row;
      gap: var(--spacing-lg);
    }
  }
</style>
